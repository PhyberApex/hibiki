# Copy this file to .env at the repo root (same folder as package.json).
# Discord bot (required)
DISCORD_TOKEN=
DISCORD_CLIENT_ID=

# Optional: default guild for slash commands / testing
# DISCORD_GUILD_ID=

# Bot command prefix (default: !)
# HIBIKI_PREFIX=!

# E2E only: allow this Discord user ID (e.g. sidecar bot) to send prefix commands to Hibiki.
# Set to the sidecar bot's user ID when running E2E command tests (!join, !leave, etc.).
# HIBIKI_E2E_ALLOW_BOT_ID=

# Storage paths (defaults below; use ./storage for Docker volume)
# HIBIKI_STORAGE_PATH=storage
# HIBIKI_MUSIC_DIR=storage/music
# HIBIKI_EFFECTS_DIR=storage/effects
# HIBIKI_DB_PATH=storage/data/hibiki.sqlite

# Web dashboard (built into bot at build time)
# HIBIKI_WEB_DIST=web-dist
