{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "web-dist/**"]
    },
    "lint": {},
    "lint:fix": {},
    "test": {
      "outputs": ["coverage/**"]
    },
    "test:coverage": {
      "outputs": ["coverage/**"]
    },
    "test:playwright": {
      "dependsOn": ["test"]
    }
  }
}
