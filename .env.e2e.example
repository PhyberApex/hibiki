# E2E tests (Playwright against Electron app). Copy to .env.e2e and fill in.
#
# How to run:
#   pnpm run build       # Build the Electron app first
#   pnpm run test:e2e    # Run E2E tests
#
# The tests launch the Electron app automatically (no need to start it separately).
# Requires DISCORD_TOKEN in root .env file.

# ── Test Execution ──
# Set to 1 to watch tests run in visible Electron window (default is headless for CI)
# HIBIKI_E2E_HEADED=1

# ── Voice Channel Tests ──
# Guild and voice channel for join/leave tests (optional - tests will skip if not set)
E2E_GUILD_ID=
E2E_VOICE_CHANNEL_ID=

# ── Sidecar Bot (Optional) ──
# Second bot token to verify Hibiki actually joined the voice channel.
# If not set, voice tests will only check the UI state (not actual Discord state).
#
# Sidecar bot requirements:
#   - Must be in the same guild as E2E_GUILD_ID
#   - Needs "View Channels" permission
# E2E_SIDECAR_TOKEN=
