# E2E tests (real Discord). Copy to .env.e2e and fill in.
#
# How to run:
#   1. Start Hibiki first (e.g. docker compose up -d, or pnpm dev).
#   2. From repo root: pnpm run test:e2e  (or from e2e/: pnpm test)
#
# Hibiki must be running and in the guild (same DISCORD_TOKEN as normal).

# Hibiki API base URL (default http://localhost:3000)
E2E_HIBIKI_API_URL=http://localhost:3000

# Guild and voice channel where E2E runs (required for API flow + sidecar)
E2E_GUILD_ID=
E2E_VOICE_CHANNEL_ID=

# Text channel for sidecar checks and command tests (!join, !songs, etc.). Must be in the same
# guild as E2E_GUILD_ID. Hibiki must have Read Messages / View Channel there.
E2E_TEXT_CHANNEL_ID=

# Optional: second bot token (sidecar). Bot must be in the same guild and in Hibiki's permissions
# allowlist (dashboard → Permissions). Used to verify voice state and run command tests.
#
# Sidecar bot permissions (OAuth2 URL Generator → Bot Permissions):
#   View Channels, Send Messages, Read Message History — for E2E text channel.
#   Connect, Speak — for voice channel tests (!join with sidecar in voice).
# E2E_SIDECAR_TOKEN=
#
# For command tests (!join, !leave, !songs, !effects) to work, the Hibiki process must accept
# commands from the sidecar bot. In the Hibiki .env (or docker-compose env), set:
#   HIBIKI_E2E_ALLOW_BOT_ID=<sidecar bot's Discord user ID>
# Get the sidecar's user ID from Discord Developer Portal → your sidecar application → Bot (same as
# the "Application ID" for bot-only apps, or use the "User ID" shown there).

# Optional: Hibiki command prefix if not ! (must match HIBIKI_PREFIX on the bot).
# E2E_HIBIKI_PREFIX=!
