{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Hibiki Scene Registry Entry",
  "type": "object",
  "required": ["name", "slug", "description", "author", "version", "tags", "category", "audioBundled", "createdAt", "updatedAt", "scene"],
  "additionalProperties": false,
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "description": "Human-readable scene name"
    },
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$",
      "description": "URL-safe identifier (lowercase, hyphens only)"
    },
    "description": {
      "type": "string",
      "minLength": 1,
      "description": "Short description of the scene"
    },
    "author": {
      "type": "string",
      "minLength": 1,
      "description": "Creator name or handle"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Semver version string"
    },
    "tags": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1,
      "description": "Keywords for discovery"
    },
    "category": {
      "type": "string",
      "minLength": 1,
      "description": "Scene category (e.g. environment, combat, social)"
    },
    "license": {
      "type": "string",
      "description": "SPDX license identifier for the scene definition itself"
    },
    "audioBundled": {
      "const": false,
      "description": "Must be false — the registry only accepts reference-only scenes (no bundled audio)"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 creation timestamp"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 last-update timestamp"
    },
    "scene": {
      "type": "object",
      "required": ["music", "ambience", "effects"],
      "additionalProperties": false,
      "description": "The scene definition with track references",
      "properties": {
        "music": {
          "type": "array",
          "items": { "$ref": "#/$defs/track" },
          "description": "Music tracks"
        },
        "ambience": {
          "type": "array",
          "items": { "$ref": "#/$defs/track" },
          "description": "Ambience loops"
        },
        "effects": {
          "type": "array",
          "items": { "$ref": "#/$defs/track" },
          "description": "One-shot effects"
        }
      }
    }
  },
  "$defs": {
    "track": {
      "type": "object",
      "required": ["soundName", "source"],
      "additionalProperties": false,
      "properties": {
        "soundName": {
          "type": "string",
          "minLength": 1,
          "description": "Display name of the track"
        },
        "volume": {
          "type": "number",
          "minimum": 0,
          "maximum": 100,
          "description": "Volume level (0-100, default 80)"
        },
        "enabled": {
          "type": "boolean",
          "description": "For ambience: whether it starts active"
        },
        "loop": {
          "type": "boolean",
          "description": "For music: whether it loops"
        },
        "source": {
          "type": "object",
          "required": ["name"],
          "additionalProperties": false,
          "description": "Where to find the audio file",
          "properties": {
            "name": {
              "type": "string",
              "minLength": 1,
              "description": "Name or title of the audio"
            },
            "url": {
              "type": "string",
              "description": "Link to where the audio can be found"
            },
            "note": {
              "type": "string",
              "description": "Free-text hint (e.g. 'any rain loop works')"
            }
          }
        }
      }
    }
  }
}
