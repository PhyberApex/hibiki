{
  "name": "hibiki",
  "version": "0.4.0",
  "description": "Hibiki (響) – Echoes of Adventure. Your private bard bot for Discord.",
  "private": true,
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "pnpm --filter @hibiki/app run dev",
    "build": "pnpm --filter @hibiki/app run build",
    "dist": "pnpm --filter @hibiki/app run dist",
    "dist:mac": "pnpm --filter @hibiki/app run dist:mac",
    "dist:win": "pnpm --filter @hibiki/app run dist:win",
    "dist:linux": "pnpm --filter @hibiki/app run dist:linux",
    "lint": "pnpm -r run lint",
    "lint:fix": "pnpm -r run lint:fix",
    "test": "pnpm --filter '!e2e' run test",
    "test:coverage": "pnpm -r run test:coverage",
    "test:e2e": "pnpm --filter e2e run test"
  },
  "packageManager": "pnpm@10.30.2",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@snazzah/davey",
      "electron",
      "electron-winstaller",
      "esbuild",
      "lzma-native",
      "unrs-resolver"
    ]
  }
}
