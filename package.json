{
  "name": "hibiki",
  "version": "0.3.0",
  "description": "Hibiki (響) – Echoes of Adventure a Music Bot for Discord.",
  "private": true,
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "workspaces": [
    "apps/bot",
    "apps/web",
    "e2e"
  ],
  "scripts": {
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "dev": "concurrently \"turbo run start:dev --filter=@hibiki/bot\" \"turbo run dev --filter=web\"",
    "build": "turbo run build",
    "copy:web": "node scripts/copy-web-dist.cjs",
    "start": "turbo run start:prod --filter=@hibiki/bot",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "test:e2e": "turbo run test test:playwright --filter=e2e"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "turbo": "^2.3.3"
  },
  "packageManager": "pnpm@10.30.0"
}