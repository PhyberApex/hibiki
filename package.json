{
  "name": "hibiki",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.32.0",
  "description": "Hibiki (響) – Echoes of Adventure. Your private bard bot for Discord.",
  "author": "PhyberApex",
  "license": "MIT",
  "main": "electron/main.js",
  "config": {
    "forge": "./forge.config.js"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "pnpm run build && electron-forge start",
    "build": "pnpm run build:frontend && tsc --build",
    "build:frontend": "cd frontend && vite build",
    "make": "pnpm run build && electron-forge make",
    "package": "pnpm run build && electron-forge package",
    "dist": "pnpm run make",
    "dist:mac": "pnpm run make -- --platform=darwin",
    "dist:win": "pnpm run make -- --platform=win32",
    "dist:linux": "pnpm run make -- --platform=linux",
    "lint": "eslint . frontend/",
    "lint:fix": "eslint . frontend/ --fix",
    "test": "run-p test:backend test:frontend",
    "test:backend": "jest --config jest.config.js",
    "test:frontend": "cd frontend && vitest run",
    "test:watch": "jest --watch --config jest.config.js",
    "test:coverage": "run-p test:coverage:backend test:coverage:frontend",
    "test:coverage:backend": "jest --coverage --config jest.config.js",
    "test:coverage:frontend": "cd frontend && vitest run --coverage",
    "test:e2e": "cd e2e && pnpm install --frozen-lockfile && pnpm test"
  },
  "dependencies": {
    "@discordjs/opus": "^0.10.0",
    "@discordjs/rest": "^2.3.0",
    "@discordjs/voice": "^0.19.0",
    "@noble/ciphers": "^2.1.1",
    "@snazzah/davey": "^0.1.10",
    "adm-zip": "^0.5.16",
    "discord-api-types": "^0.38.0",
    "discord.js": "^14.22.0",
    "dotenv": "^16.4.5",
    "fast-glob": "^3.3.2",
    "joi": "^18.0.2",
    "node-audio-mixer": "^2.1.0",
    "opusscript": "^0.1.1",
    "pinia": "^3.0.4",
    "prism-media": "^1.3.5",
    "slugify": "^1.6.6",
    "vue": "^3.5.27",
    "vue-router": "^5.0.1"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.4.3",
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-deb": "^7.11.1",
    "@electron-forge/maker-dmg": "^7.11.1",
    "@electron-forge/maker-squirrel": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@electron-forge/plugin-vite": "^7.11.1",
    "@tsconfig/node24": "^24.0.4",
    "@types/adm-zip": "^0.5.7",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.10.7",
    "@vitejs/plugin-vue": "^6.0.3",
    "@vitest/coverage-v8": "^4.0.0",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.9.0",
    "electron": "^33.0.0",
    "eslint": "^10.0.0",
    "jest": "^30.2.0",
    "jest-junit": "^16.0.0",
    "jsdom": "^28.0.0",
    "npm-run-all2": "^8.0.4",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "vite": "^7.3.1",
    "vite-plugin-vue-devtools": "^8.0.5",
    "vitest": "^4.0.0",
    "vue-tsc": "^3.2.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@discordjs/opus",
      "@snazzah/davey",
      "electron",
      "electron-winstaller",
      "esbuild",
      "fs-xattr",
      "lzma-native",
      "macos-alias",
      "unrs-resolver"
    ]
  }
}
