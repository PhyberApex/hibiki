{
  "name": "@hibiki/app",
  "version": "0.4.0",
  "private": true,
  "description": "Hibiki – Discord audio bot + web dashboard (Electron app)",
  "author": "PhyberApex",
  "license": "MIT",
  "main": "electron/main.js",
  "scripts": {
    "dev": "pnpm run build && electron .",
    "build": "pnpm run build:frontend && tsc",
    "build:frontend": "cd frontend && vite build",
    "dist": "pnpm run build && electron-builder --publish never",
    "dist:mac": "pnpm run build && electron-builder --mac --publish never",
    "dist:win": "pnpm run build && electron-builder --win --publish never",
    "dist:linux": "pnpm run build && electron-builder --linux --publish never",
    "lint": "eslint . frontend/",
    "lint:fix": "eslint . frontend/ --fix",
    "test": "run-p test:backend test:frontend",
    "test:backend": "jest --config jest.config.js",
    "test:frontend": "cd frontend && vitest run",
    "test:watch": "jest --watch --config jest.config.js",
    "test:coverage": "run-p test:coverage:backend test:coverage:frontend",
    "test:coverage:backend": "jest --coverage --config jest.config.js",
    "test:coverage:frontend": "cd frontend && vitest run --coverage"
  },
  "build": {
    "appId": "com.phyberapex.hibiki",
    "productName": "Hibiki",
    "npmRebuild": true,
    "buildDependenciesFromSource": true,
    "directories": {
      "output": "release"
    },
    "asarUnpack": [
      "**/*.node"
    ],
    "files": [
      "electron/**/*",
      "dist/**/*",
      "web-dist/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.music",
      "target": [
        { "target": "dmg", "arch": ["x64", "arm64"] },
        { "target": "zip", "arch": ["x64", "arm64"] }
      ],
      "icon": "frontend/public/logo.png"
    },
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ],
      "icon": "frontend/public/logo.png"
    },
    "linux": {
      "target": [
        { "target": "AppImage", "arch": ["x64"] },
        { "target": "deb", "arch": ["x64"] }
      ],
      "category": "Audio",
      "icon": "frontend/public/logo.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "@discordjs/opus": "^0.10.0",
    "@discordjs/rest": "^2.3.0",
    "@discordjs/voice": "^0.18.0",
    "adm-zip": "^0.5.16",
    "discord-api-types": "^0.38.0",
    "discord.js": "^14.22.0",
    "dotenv": "^16.4.5",
    "fast-glob": "^3.3.2",
    "joi": "^18.0.2",
    "node-audio-mixer": "^2.1.0",
    "opusscript": "^0.1.1",
    "pinia": "^3.0.4",
    "prism-media": "^1.3.5",
    "slugify": "^1.6.6",
    "vue": "^3.5.27",
    "vue-router": "^5.0.1"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.4.3",
    "@tsconfig/node24": "^24.0.4",
    "@types/adm-zip": "^0.5.7",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.10.7",
    "@vitejs/plugin-vue": "^6.0.3",
    "@vitest/coverage-v8": "^4.0.0",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.8.1",
    "electron": "^33.0.0",
    "electron-builder": "^26.8.1",
    "eslint": "^10.0.0",
    "jest": "^30.2.0",
    "jest-junit": "^16.0.0",
    "jsdom": "^28.0.0",
    "npm-run-all2": "^8.0.4",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "vite": "^7.3.1",
    "vite-plugin-vue-devtools": "^8.0.5",
    "vitest": "^4.0.0",
    "vue-tsc": "^3.2.4"
  }
}
